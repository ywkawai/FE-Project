contains
% for p in 1..AUTOGEN_PMAX
% np = p+1
% np_div3 = ((p+1)/3.0).round
% np_div3_res = np - np_div3*2
!--- For p=<%=p%> ------------------------------------

!> Calculate a matrix-vector multiplication associated with mathematical operations in the z direction (third dimension of vec_in) with p=<%=p%>
!! For a matrix-vector multiplication (vec_out = Mat_z vec_in), the passed variable of Mat_z should be transposed.
!!
!OCL SERIAL
  subroutine element_operation_kernel_matvec_dirZ_P<%=p%>( Mat_z_tr, vec_in, Ne_in, Ne_out, vec_out )
    implicit none
    integer, intent(in) :: Ne_in
    integer, intent(in) :: Ne_out
    real(RP), intent(in) :: Mat_z_tr(<%=np%>,<%=np%>)
    real(RP), intent(in) :: vec_in(<%=np%>**2,<%=np%>,Ne_in)
    real(RP), intent(out) :: vec_out(<%=np%>**2,<%=np%>,Ne_out)

    integer :: ij, k, ke
    !----------------------------------------------------------

    !$acc parallel loop gang collapse(2) present(Mat_z_tr,vec_in,vec_out) async(1)
    do ke=1, Ne_out
    do k=1, <%=np%>
    do ij=1, <%=np%>**2
        vec_out(ij,k,ke) = vec_in(ij,1,ke) * Mat_z_tr(1,k) &
% for kk in 2..np-1
                      + vec_in(ij,<%=kk%>,ke) * Mat_z_tr(<%=kk%>,k) &
% end
                      + vec_in(ij,<%=np%>,ke) * Mat_z_tr(<%=np%>,k) 
    end do
    end do
    end do

    return
  end subroutine element_operation_kernel_matvec_dirZ_P<%=p%>

  subroutine element_operation_kernel_matvec_divlike_dirXY_P<%=p%>( &
    Mat, Mat_tr, vec_in_x, vec_in_y, &
    E11, E22, &
    div_out_xy  )
    implicit none
    real(RP), intent(in) :: Mat(<%=np%>,<%=np%>)
    real(RP), intent(in) :: Mat_tr(<%=np%>,<%=np%>)
    real(RP), intent(in) :: vec_in_x(<%=np%>,<%=np%>)
    real(RP), intent(in) :: vec_in_y(<%=np%>,<%=np%>)
    real(RP), intent(in) :: E11(<%=np%>,<%=np%>)
    real(RP), intent(in) :: E22(<%=np%>,<%=np%>)
    real(RP), intent(out) :: div_out_xy(<%=np%>,<%=np%>)

    integer :: i, j, jv, jk
    real(RP) :: tmp1, div_x
% if p > 7
    real(RP) :: tmp2, tmp3
% end
    !----------------------------------------------------------
    !$acc routine vector

    !$acc loop vector collapse(2)
    do j=1, <%=np%>
    do i=1, <%=np%>
      ! X-dir
% if p <= 7
      div_x = ( Mat(i,1) * vec_in_x(1,j) &

%   for ii in 2..np-1
            + Mat(i,<%=ii%>) * vec_in_x(<%=ii%>,j) &
%   end
            + Mat(i,<%=np%>) * vec_in_x(<%=np%>,j) ) * E11(i,j)
% else
      tmp1 = Mat(i,1) * vec_in_x(1,j) &
%   for ii in 2..np_div3-1
           + Mat(i,<%=ii%>) * vec_in_x(<%=ii%>,j) &
%   end
           + Mat(i,<%=np_div3%>) * vec_in_x(<%=np_div3%>,j)
      tmp2 = Mat(i,<%=np_div3+1%>) * vec_in_x(<%=np_div3+1%>,j) &
%   for ii in np_div3+2..np_div3*2-1
           + Mat(i,<%=ii%>) * vec_in_x(<%=ii%>,j) &
%   end
           + Mat(i,<%=np_div3*2%>) * vec_in_x(<%=np_div3*2%>,j)
      tmp3 = Mat(i,<%=np_div3*2+1%>) * vec_in_x(<%=np_div3*2+1%>,j) &
%   for ii in np_div3*2+2..np-1
           + Mat(i,<%=ii%>) * vec_in_x(<%=ii%>,j) &
%   end
           + Mat(i,<%=np%>) * vec_in_x(<%=np%>,j)
      div_x = ( tmp1 + tmp2 + tmp3 ) * E11(i,j)
% end

      ! Y-dir
% if p <= 7
      tmp1 = vec_in_y(i,1) * Mat_tr(1,j) &
%   for jj in 2..np-1
           + vec_in_y(i,<%=jj%>) * Mat_tr(<%=jj%>,j) &
%   end
           + vec_in_y(i,<%=np%>) * Mat_tr(<%=np%>,j) 
    div_out_xy(i,j) = div_x + tmp1 * E22(i,j)
% else
      tmp1 = vec_in_y(i,1) * Mat_tr(1,j) &
%   for jj in 2..np_div3-1
           + vec_in_y(i,<%=jj%>) * Mat_tr(<%=jj%>,j) &
%   end
           + vec_in_y(i,<%=np_div3%>) * Mat_tr(<%=np_div3%>,j) 
      tmp2 = vec_in_y(i,<%=np_div3+1%>) * Mat_tr(<%=np_div3+1%>,j) &
%   for jj in np_div3+2..np_div3*2-1
           + vec_in_y(i,<%=jj%>) * Mat_tr(<%=jj%>,j) &
%   end
           + vec_in_y(i,<%=np_div3*2%>) * Mat_tr(<%=np_div3*2%>,j) 
      tmp3 = vec_in_y(i,<%=np_div3*2+1%>) * Mat_tr(<%=np_div3*2+1%>,j) &
%   for jj in np_div3*2+2..np-1
           + vec_in_y(i,<%=jj%>) * Mat_tr(<%=jj%>,j) &
%   end
           + vec_in_y(i,<%=np%>) * Mat_tr(<%=np%>,j) 
      div_out_xy(i,j) = div_x + ( tmp1 + tmp2 + tmp3 ) * E22(i,j)
% end
    end do
    end do
    return
  end subroutine element_operation_kernel_matvec_divlike_dirXY_P<%=p%>

