  subroutine element_operation_kernel_matvec_divlike_dirZ_lift_var5_P<%=p%>( &
    Mat_tr, Lift, vec_in_z, ebnd_flux, E33, Gsqrt, &
    div3D  )
    implicit none
    real(RP), intent(in) :: Mat_tr(<%=np%>,<%=np%>)
    real(RP), intent(in) :: Lift(<%=np%>,<%=np%>,<%=np%>,6)
    real(RP), intent(in) :: vec_in_z(<%=np%>,<%=np%>,5,<%=np%>)
    real(RP), intent(in) :: ebnd_flux(<%=np%>,<%=np%>,6,5)
    real(RP), intent(in) :: E33(<%=np%>,<%=np%>,<%=np%>)
    real(RP), intent(in) :: Gsqrt(<%=np%>,<%=np%>,<%=np%>)
    real(RP), intent(inout) :: div3D(<%=np%>,<%=np%>,5,<%=np%>)

    integer :: i, j, k, v
    real(RP) :: tmp1
    real(RP) :: tmp_lift
    real(RP) :: tmp2, tmp3    
% if p > 7
% end
    real(RP) :: invG, e33_
    !----------------------------------------------------------

    !$acc routine vector
    
    ! Z-dir
    do v=1, 5    
    do k=1, <%=np%>
      !$acc loop vector collapse(2)
      do j=1, <%=np%>
      do i=1, <%=np%>
        invG = 1.0_RP / Gsqrt(i,j,k)
        e33_ = E33(i,j,k)


        tmp1 = Lift(i,j,k,1) * ebnd_flux(i,k,1,v) &
             + Lift(i,j,k,3) * ebnd_flux(i,k,3,v)
        tmp2 = Lift(i,j,k,2) * ebnd_flux(j,k,2,v) &
             + Lift(i,j,k,4) * ebnd_flux(j,k,4,v)
        tmp3 = Lift(i,j,k,5) * ebnd_flux(i,j,5,v) &
             + Lift(i,j,k,6) * ebnd_flux(i,j,6,v)
        tmp_lift = tmp1 + tmp2 + tmp3

% if p <= 7
        tmp1 = vec_in_z(i,j,v,1) * Mat_tr(1,k) &
%   for kk in 2..np-1
             + vec_in_z(i,j,v,<%=kk%>) * Mat_tr(<%=kk%>,k) &
%   end
             + vec_in_z(i,j,v,<%=np%>) * Mat_tr(<%=np%>,k) 
!        div3D(i,j,v,k) = ( div3D(i,j,v,k) + tmp1 * E33(i,j,k) ) / Gsqrt(i,j,k)
         div3D(i,j,v,k) = ( div3D(i,j,v,k) + tmp1 * e33_ + tmp_lift ) * invG

% else
        tmp1 = vec_in_z(i,j,v,1) * Mat_tr(1,k) &
%   for kk in 2..np_div3-1
             + vec_in_z(i,j,v,<%=kk%>) * Mat_tr(<%=kk%>,k) &
%   end
             + vec_in_z(i,j,v,<%=np_div3%>) * Mat_tr(<%=np_div3%>,k) 
        tmp2 = vec_in_z(i,j,v,<%=np_div3+1%>) * Mat_tr(<%=np_div3+1%>,k) &
%   for kk in np_div3+2..np_div3*2-1
             + vec_in_z(i,j,v,<%=kk%>) * Mat_tr(<%=kk%>,k) &
%   end
             + vec_in_z(i,j,v,<%=np_div3*2%>) * Mat_tr(<%=np_div3*2%>,k) 
        tmp3 = vec_in_z(i,j,v,<%=np_div3*2+1%>) * Mat_tr(<%=np_div3*2+1%>,k) &
%   for kk in np_div3*2+2..np-1
             + vec_in_z(i,j,v,<%=kk%>) * Mat_tr(<%=kk%>,k) &
%   end
             + vec_in_z(i,j,v,<%=np%>) * Mat_tr(<%=np%>,k) 
!        div3D(i,j,v,k) = ( div3D(i,j,v,k) + ( tmp1 + tmp2 + tmp3 ) * E33(i,j,k) ) / Gsqrt(i,j,k)
        div3D(i,j,v,k) = ( div3D(i,j,v,k) + ( tmp1 + tmp2 + tmp3 ) * e33_ + tmp_lift ) * invG
% end
      end do
      end do
    end do
    end do
    return
  end subroutine element_operation_kernel_matvec_divlike_dirZ_lift_var5_P<%=p%>

  subroutine element_operation_kernel_matvec_divlike_var5_P<%=p%>( &
    Mat, Mat_tr, Lift, vec_in_x, vec_in_y, vec_in_z, ebnd_flux, E11, E22, E33, Gsqrt, &
    Ne, &
    div3D  )
    implicit none
    real(RP), intent(in) :: Mat(<%=np%>,<%=np%>)
    real(RP), intent(in) :: Mat_tr(<%=np%>,<%=np%>)
    real(RP), intent(in) :: Lift(<%=np%>,<%=np%>,<%=np%>,6)
    integer, intent(in) :: Ne
    real(RP), intent(in) :: vec_in_x(<%=np%>,<%=np%>,5,<%=np%>,Ne)
    real(RP), intent(in) :: vec_in_y(<%=np%>,<%=np%>,5,<%=np%>,Ne)
    real(RP), intent(in) :: vec_in_z(<%=np%>,<%=np%>,5,<%=np%>,Ne)
    real(RP), intent(in) :: ebnd_flux(<%=np%>,<%=np%>,6,5,Ne)
    real(RP), intent(in) :: E11(<%=np%>,<%=np%>,<%=np%>,Ne)
    real(RP), intent(in) :: E22(<%=np%>,<%=np%>,<%=np%>,Ne)
    real(RP), intent(in) :: E33(<%=np%>,<%=np%>,<%=np%>,Ne)
    real(RP), intent(in) :: Gsqrt(<%=np%>,<%=np%>,<%=np%>,Ne)
    real(RP), intent(inout) :: div3D(<%=np%>,<%=np%>,5,<%=np%>,Ne)

    integer :: ke
    integer :: i, j, k, v
    real(RP) :: tmp1
    real(RP) :: tmp_lift
    real(RP) :: tmp2, tmp3    
% if p > 7
% end
    real(RP) :: invG, e33_
    real(RP) :: div_x, div_xy
    !----------------------------------------------------------

    !$acc parallel loop gang collapse(2) present(Mat,Mat_tr,vec_in_x,vec_in_y,vec_in_z,Lift,ebnd_flux,E11,E22,E33,Gsqrt,div3D) async(1)
    do ke=1, Ne
    do k=1, <%=np%>
      do v=1, 5
        !$acc loop vector collapse(2)
        do j=1, <%=np%>
        do i=1, <%=np%>
          ! X-dir
% if p <= 7
          div_x = ( Mat(i,1) * vec_in_x(1,j,v,k,ke) &

%   for ii in 2..np-1
                + Mat(i,<%=ii%>) * vec_in_x(<%=ii%>,j,v,k,ke) &
%   end
                + Mat(i,<%=np%>) * vec_in_x(<%=np%>,j,v,k,ke) ) * E11(i,j,k,ke)
% else
          tmp1 = Mat(i,1) * vec_in_x(1,j,v,k,ke) &
%   for ii in 2..np_div3-1
               + Mat(i,<%=ii%>) * vec_in_x(<%=ii%>,j,v,k,ke) &
%   end
               + Mat(i,<%=np_div3%>) * vec_in_x(<%=np_div3%>,j,v,k,ke)
          tmp2 = Mat(i,<%=np_div3+1%>) * vec_in_x(<%=np_div3+1%>,j,v,k,ke) &
%   for ii in np_div3+2..np_div3*2-1
               + Mat(i,<%=ii%>) * vec_in_x(<%=ii%>,j,v,k,ke) &
%   end
               + Mat(i,<%=np_div3*2%>) * vec_in_x(<%=np_div3*2%>,j,v,k,ke)
          tmp3 = Mat(i,<%=np_div3*2+1%>) * vec_in_x(<%=np_div3*2+1%>,j,v,k,ke) &
%   for ii in np_div3*2+2..np-1
               + Mat(i,<%=ii%>) * vec_in_x(<%=ii%>,j,v,k,ke) &
%   end
               + Mat(i,<%=np%>) * vec_in_x(<%=np%>,j,v,k,ke)
          div_x = ( tmp1 + tmp2 + tmp3 ) * E11(i,j,k,ke)
% end

          ! Y-dir
% if p <= 7
          tmp1 = vec_in_y(i,1,v,k,ke) * Mat_tr(1,j) &
%   for jj in 2..np-1
               + vec_in_y(i,<%=jj%>,v,k,ke) * Mat_tr(<%=jj%>,j) &
%   end
               + vec_in_y(i,<%=np%>,v,k,ke) * Mat_tr(<%=np%>,j) 
!          div3D(i,j,v,k,ke) = div_x + tmp1 * E22(i,j,k,ke)
           div_xy = div_x + tmp1 * E22(i,j,k,ke)
% else
          tmp1 = vec_in_y(i,1,v,k,ke) * Mat_tr(1,j) &
%   for jj in 2..np_div3-1
               + vec_in_y(i,<%=jj%>,v,k,ke) * Mat_tr(<%=jj%>,j) &
%   end
              + vec_in_y(i,<%=np_div3%>,v,k,ke) * Mat_tr(<%=np_div3%>,j) 
          tmp2 = vec_in_y(i,<%=np_div3+1%>,v,k,ke) * Mat_tr(<%=np_div3+1%>,j) &
%   for jj in np_div3+2..np_div3*2-1
               + vec_in_y(i,<%=jj%>,v,k,ke) * Mat_tr(<%=jj%>,j) &
%   end
               + vec_in_y(i,<%=np_div3*2%>,v,k,ke) * Mat_tr(<%=np_div3*2%>,j) 
          tmp3 = vec_in_y(i,<%=np_div3*2+1%>,v,k,ke) * Mat_tr(<%=np_div3*2+1%>,j) &
%   for jj in np_div3*2+2..np-1
               + vec_in_y(i,<%=jj%>,v,k,ke) * Mat_tr(<%=jj%>,j) &
%   end
               + vec_in_y(i,<%=np%>,v,k,ke) * Mat_tr(<%=np%>,j) 
!          div3D(i,j,v,k,ke) = div_x + ( tmp1 + tmp2 + tmp3 ) * E22(i,j,k,ke)
          div_xy = div_x + ( tmp1 + tmp2 + tmp3 ) * E22(i,j,k,ke)
% end
        !end do
        !end do
      !end do
    !end do
    !end do

    !!$acc parallel loop gang collapse(2) present(Mat_tr,Lift,vec_in_z,ebnd_flux,E33,Gsqrt,div3D)
    !do ke=1, Ne
      ! Z-dir
      !do k=1, <%=np%>      
      !do v=1, 5    
        !!$acc loop vector collapse(2)
        !do j=1, <%=np%>
        !do i=1, <%=np%>
          invG = 1.0_RP / Gsqrt(i,j,k,ke)
          e33_ = E33(i,j,k,ke)


          tmp1 = Lift(i,j,k,1) * ebnd_flux(i,k,1,v,ke) &
              + Lift(i,j,k,3) * ebnd_flux(i,k,3,v,ke)
          tmp2 = Lift(i,j,k,2) * ebnd_flux(j,k,2,v,ke) &
              + Lift(i,j,k,4) * ebnd_flux(j,k,4,v,ke)
          tmp3 = Lift(i,j,k,5) * ebnd_flux(i,j,5,v,ke) &
              + Lift(i,j,k,6) * ebnd_flux(i,j,6,v,ke)
          tmp_lift = tmp1 + tmp2 + tmp3

% if p <= 7
          tmp1 = vec_in_z(i,j,v,1,ke) * Mat_tr(1,k) &
%   for kk in 2..np-1
              + vec_in_z(i,j,v,<%=kk%>,ke) * Mat_tr(<%=kk%>,k) &
%   end
              + vec_in_z(i,j,v,<%=np%>,ke) * Mat_tr(<%=np%>,k) 
!          div3D(i,j,v,k,ke) = ( div3D(i,j,v,k,ke) + tmp1 * e33_ + tmp_lift ) * invG
          div3D(i,j,v,k,ke) = ( div_xy + tmp1 * e33_ + tmp_lift ) * invG

% else
          tmp1 = vec_in_z(i,j,v,1,ke) * Mat_tr(1,k) &
%   for kk in 2..np_div3-1
               + vec_in_z(i,j,v,<%=kk%>,ke) * Mat_tr(<%=kk%>,k) &
%   end
               + vec_in_z(i,j,v,<%=np_div3%>,ke) * Mat_tr(<%=np_div3%>,k) 
          tmp2 = vec_in_z(i,j,v,<%=np_div3+1%>,ke) * Mat_tr(<%=np_div3+1%>,k) &
%   for kk in np_div3+2..np_div3*2-1
               + vec_in_z(i,j,v,<%=kk%>,ke) * Mat_tr(<%=kk%>,k) &
%   end
               + vec_in_z(i,j,v,<%=np_div3*2%>,ke) * Mat_tr(<%=np_div3*2%>,k) 
          tmp3 = vec_in_z(i,j,v,<%=np_div3*2+1%>,ke) * Mat_tr(<%=np_div3*2+1%>,k) &
%   for kk in np_div3*2+2..np-1
               + vec_in_z(i,j,v,<%=kk%>,ke) * Mat_tr(<%=kk%>,k) &
%   end
               + vec_in_z(i,j,v,<%=np%>,ke) * Mat_tr(<%=np%>,k) 
!          div3D(i,j,v,k,ke) = ( div3D(i,j,v,k,ke) + ( tmp1 + tmp2 + tmp3 ) * e33_ + tmp_lift ) * invG
          div3D(i,j,v,k,ke) = ( div_xy + ( tmp1 + tmp2 + tmp3 ) * e33_ + tmp_lift ) * invG

% end
        end do
        end do
      end do
    end do
    end do
    return
  end subroutine element_operation_kernel_matvec_divlike_var5_P<%=p%>

  subroutine element_operation_kernel_matvec_divlike_var5_P<%=p%>_v2( &
    Mat, Mat_tr, Lift, vec_in_x, vec_in_y, vec_in_z, ebnd_flux, E11, E22, E33, Gsqrt, &
    Ne, &
    div3D  )
    implicit none
    real(RP), intent(in) :: Mat(<%=np%>,<%=np%>)
    real(RP), intent(in) :: Mat_tr(<%=np%>,<%=np%>)
    real(RP), intent(in) :: Lift(<%=np%>,<%=np%>,<%=np%>,6)
    integer, intent(in) :: Ne
    real(RP), intent(in) :: vec_in_x(<%=np%>,<%=np%>,5,<%=np%>,Ne)
    real(RP), intent(in) :: vec_in_y(<%=np%>,<%=np%>,5,<%=np%>,Ne)
    real(RP), intent(in) :: vec_in_z(<%=np%>,<%=np%>,5,<%=np%>,Ne)
    real(RP), intent(in) :: ebnd_flux(<%=np%>,<%=np%>,6,5,Ne)
    real(RP), intent(in) :: E11(<%=np%>,<%=np%>,<%=np%>,Ne)
    real(RP), intent(in) :: E22(<%=np%>,<%=np%>,<%=np%>,Ne)
    real(RP), intent(in) :: E33(<%=np%>,<%=np%>,<%=np%>,Ne)
    real(RP), intent(in) :: Gsqrt(<%=np%>,<%=np%>,<%=np%>,Ne)
    real(RP), intent(inout) :: div3D(<%=np%>,<%=np%>,5,<%=np%>,Ne)

    integer :: ke
    integer :: p, i, j, k, v
    real(RP) :: tmp1
    real(RP) :: tmp_lift
    real(RP) :: tmp2, tmp3    

    real(RP) :: invG, e33_
    real(RP) :: div_x, div_xy
    !----------------------------------------------------------

    !$acc parallel loop gang collapse(2) present(Mat,Mat_tr,vec_in_x,vec_in_y,vec_in_z,Lift,ebnd_flux,E11,E22,E33,Gsqrt,div3D) async(1)
    do ke=1, Ne
    do k=1, <%=np%>
      do v=1, 5
        !$acc loop vector collapse(2)
        do j=1, <%=np%>
        do i=1, <%=np%>
          ! X-dir
          div_x = 0.0_RP
          !$acc loop seq
          do p=1, <%=np%>
            div_x = div_x + Mat(i,p) * vec_in_x(p,j,v,k,ke)
          end do

          ! Y-dir
          tmp1 = 0.0_RP
          !$acc loop seq
          do p=1, <%=np%>
            tmp1 = tmp1 + vec_in_y(i,p,v,k,ke) * Mat_tr(p,j)
          end do
          div_xy = div_x * E11(i,j,k,ke) + tmp1 * E22(i,j,k,ke)

          !- Lift

          invG = 1.0_RP / Gsqrt(i,j,k,ke)
          e33_ = E33(i,j,k,ke)


          tmp1 = Lift(i,j,k,1) * ebnd_flux(i,k,1,v,ke) &
              + Lift(i,j,k,3) * ebnd_flux(i,k,3,v,ke)
          tmp2 = Lift(i,j,k,2) * ebnd_flux(j,k,2,v,ke) &
              + Lift(i,j,k,4) * ebnd_flux(j,k,4,v,ke)
          tmp3 = Lift(i,j,k,5) * ebnd_flux(i,j,5,v,ke) &
              + Lift(i,j,k,6) * ebnd_flux(i,j,6,v,ke)
          tmp_lift = tmp1 + tmp2 + tmp3

          ! Z-dir
          tmp1 = 0.0_RP
          !$acc loop seq
          do p=1, <%=np%>
            tmp1 = tmp1 + vec_in_z(i,j,v,p,ke) * Mat_tr(p,k)
          end do
          div3D(i,j,v,k,ke) = ( div_xy + tmp1 * e33_ + tmp_lift ) * invG

        end do
        end do
      end do
    end do
    end do
    return
  end subroutine element_operation_kernel_matvec_divlike_var5_P<%=p%>_v2


!> Calculate a matrix-vector multiplication associated with 3D modal filtering with p=<%=p%>
!!
!OCL SERIAL
  subroutine element_operation_kernel_matvec_ModalFilter_P<%=p%>( Mat_h1D, Mat_h1D_tr, Mat_v1D_tr, vec_in, vec_work, &
    Ne,      &
    vec_out  )
    implicit none
    integer, intent(in) :: Ne
    real(RP), intent(in) :: Mat_h1D(<%=np%>,<%=np%>)
    real(RP), intent(in) :: Mat_h1D_tr(<%=np%>,<%=np%>)
    real(RP), intent(in) :: Mat_v1D_tr(<%=np%>,<%=np%>)
    real(RP), intent(in) :: vec_in(<%=np%>,<%=np%>,<%=np%>,Ne)
    real(RP), intent(out) :: vec_work(<%=np%>,<%=np%>,<%=np%>,Ne)
    real(RP), intent(out) :: vec_out(<%=np%>,<%=np%>,<%=np%>,Ne)

    integer :: ke
    integer :: i, j, k
% if p > 7
    real(RP) :: tmp1, tmp2, tmp3
% end
    !----------------------------------------------------------

    ! X-dir
    !$acc parallel loop gang collapse(2) present(Mat_h1D,Mat_h1D_tr,Mat_v1D_tr,vec_in,vec_work,vec_out) async(1)
    do ke=1, Ne
    do k=1, <%=np%>
      !$acc loop vector collapse(2)
      do j=1, <%=np%>
      do i=1, <%=np%>
% if p <= 7
        vec_out(i,j,k,ke) = Mat_h1D(i,1) * vec_in(1,j,k,ke) &
%   for ii in 2..np-1
                       + Mat_h1D(i,<%=ii%>) * vec_in(<%=ii%>,j,k,ke) &
%   end
                       + Mat_h1D(i,<%=np%>) * vec_in(<%=np%>,j,k,ke)
% else
        tmp1 = Mat_h1D(i,1) * vec_in(1,j,k,ke) &
%   for ii in 2..np_div3-1
             + Mat_h1D(i,<%=ii%>) * vec_in(<%=ii%>,j,k,ke) &
%   end
             + Mat_h1D(i,<%=np_div3%>) * vec_in(<%=np_div3%>,j,k,ke)
        tmp2 = Mat_h1D(i,<%=np_div3+1%>) * vec_in(<%=np_div3+1%>,j,k,ke) &
%   for ii in np_div3+2..np_div3*2-1
             + Mat_h1D(i,<%=ii%>) * vec_in(<%=ii%>,j,k,ke) &
%   end
             + Mat_h1D(i,<%=np_div3*2%>) * vec_in(<%=np_div3*2%>,j,k,ke)
        tmp3 = Mat_h1D(i,<%=np_div3*2+1%>) * vec_in(<%=np_div3*2+1%>,j,k,ke) &
%   for ii in np_div3*2+2..np-1
             + Mat_h1D(i,<%=ii%>) * vec_in(<%=ii%>,j,k,ke) &
%   end
             + Mat_h1D(i,<%=np%>) * vec_in(<%=np%>,j,k,ke)
        vec_out(i,j,k,ke) = tmp1 + tmp2 + tmp3
% end
      end do
      end do
    end do
    end do
    
    ! Y-dir
    !$acc parallel loop gang collapse(2) present(Mat_h1D,Mat_h1D_tr,Mat_v1D_tr,vec_in,vec_work,vec_out) async(1)
    do ke=1, Ne
    do k=1, <%=np%>
      !$acc loop vector collapse(2)
      do j=1, <%=np%>
      do i=1, <%=np%>
% if p <= 7
        vec_work(i,j,k,ke) = vec_out(i,1,k,ke) * Mat_h1D_tr(1,j) &
%   for jj in 2..np-1
                        + vec_out(i,<%=jj%>,k,ke) * Mat_h1D_tr(<%=jj%>,j) &
%   end
                        + vec_out(i,<%=np%>,k,ke) * Mat_h1D_tr(<%=np%>,j) 
% else
        tmp1 = vec_out(i,1,k,ke) * Mat_h1D_tr(1,j) &
%   for jj in 2..np_div3-1
             + vec_out(i,<%=jj%>,k,ke) * Mat_h1D_tr(<%=jj%>,j) &
%   end
             + vec_out(i,<%=np_div3%>,k,ke) * Mat_h1D_tr(<%=np_div3%>,j) 
        tmp2 = vec_out(i,<%=np_div3+1%>,k,ke) * Mat_h1D_tr(<%=np_div3+1%>,j) &
%   for jj in np_div3+2..np_div3*2-1
             + vec_out(i,<%=jj%>,k,ke) * Mat_h1D_tr(<%=jj%>,j) &
%   end
             + vec_out(i,<%=np_div3*2%>,k,ke) * Mat_h1D_tr(<%=np_div3*2%>,j) 
        tmp3 = vec_out(i,<%=np_div3*2+1%>,k,ke) * Mat_h1D_tr(<%=np_div3*2+1%>,j) &
%   for jj in np_div3*2+2..np-1
             + vec_out(i,<%=jj%>,k,ke) * Mat_h1D_tr(<%=jj%>,j) &
%   end
             + vec_out(i,<%=np%>,k,ke) * Mat_h1D_tr(<%=np%>,j) 
        vec_work(i,j,k,ke) = tmp1 + tmp2 + tmp3
% end                        
      end do
      end do
    end do
    end do
    
    ! Z-dir
    !$acc parallel loop gang collapse(2) present(Mat_h1D,Mat_h1D_tr,Mat_v1D_tr,vec_in,vec_work,vec_out) async(1)
    do ke=1, Ne
    do k=1, <%=np%>
      !$acc loop vector collapse(2)
      do j=1, <%=np%>
      do i=1, <%=np%>
% if p <= 7
        vec_out(i,j,k,ke) = vec_work(i,j,1,ke) * Mat_v1D_tr(1,k) &
%   for kk in 2..np-1
                       + vec_work(i,j,<%=kk%>,ke) * Mat_v1D_tr(<%=kk%>,k) &
%   end
                       + vec_work(i,j,<%=np%>,ke) * Mat_v1D_tr(<%=np%>,k) 
% else
        tmp1 = vec_work(i,j,1,ke) * Mat_v1D_tr(1,k) &
%   for kk in 2..np_div3-1
             + vec_work(i,j,<%=kk%>,ke) * Mat_v1D_tr(<%=kk%>,k) &
%   end
             + vec_work(i,j,<%=np_div3%>,ke) * Mat_v1D_tr(<%=np_div3%>,k) 
        tmp2 = vec_work(i,j,<%=np_div3+1%>,ke) * Mat_v1D_tr(<%=np_div3+1%>,k) &
%   for kk in np_div3+2..np_div3*2-1
             + vec_work(i,j,<%=kk%>,ke) * Mat_v1D_tr(<%=kk%>,k) &
%   end
             + vec_work(i,j,<%=np_div3*2%>,ke) * Mat_v1D_tr(<%=np_div3*2%>,k) 
        tmp3 = vec_work(i,j,<%=np_div3*2+1%>,ke) * Mat_v1D_tr(<%=np_div3*2+1%>,k) &
%   for kk in np_div3*2+2..np-1
             + vec_work(i,j,<%=kk%>,ke) * Mat_v1D_tr(<%=kk%>,k) &
%   end
             + vec_work(i,j,<%=np%>,ke) * Mat_v1D_tr(<%=np%>,k) 
        vec_out(i,j,k,ke) = tmp1 + tmp2 + tmp3
% end                       
      end do
      end do
    end do
    end do
    return
  end subroutine element_operation_kernel_matvec_ModalFilter_P<%=p%>

% end

